# =============================================================================
# STUDIO CMS - Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
#

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/studio_cms"

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Twitter/X OAuth
# Create at: https://developer.twitter.com/en/portal/projects
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

# Email Provider (Magic Links)
# Use services like Resend, SendGrid, Postmark
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Studio CMS <noreply@yourdomain.com>"

# =============================================================================
# PAYMENTS (Stripe)
# =============================================================================
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=""
STRIPE_STARTER_YEARLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=""
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=""

# =============================================================================
# FILE STORAGE
# =============================================================================
# AWS S3 or compatible (DigitalOcean Spaces, Cloudflare R2, etc.)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Or use Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Or use Uploadthing
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Google Analytics
NEXT_PUBLIC_GA_ID=""

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# ERROR TRACKING (Optional)
# =============================================================================
# Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# LaunchDarkly, Split.io, etc.
LAUNCHDARKLY_SDK_KEY=""

# =============================================================================
# DEVELOPMENT
# =============================================================================
# Set to "development" or "production"
NODE_ENV="development"
